rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'zwahraahmad31@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner'))
      );
    }
    
    function isOwnerAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'zwahraahmad31@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner')
      );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'photoURL', 'email', 'role', 'createdAt']) &&
             data.keys().size() == 5 &&
             data.displayName is string && data.displayName.size() <= 50 &&
             data.photoURL is string && data.photoURL.size() <= 600000 &&
             data.email is string && data.email.size() <= 150 &&
             data.role is string && data.role in ['user', 'admin', 'owner'] &&
             data.createdAt == request.time;
    }
    
    function isValidPhotoPost(data) {
      return data.keys().hasAll(['imageUrl', 'author', 'message', 'createdAt', 'userId']) &&
             data.keys().size() == 5 &&
             data.imageUrl is string && data.imageUrl.size() <= 500000 &&
             data.author is string && data.author.size() <= 50 &&
             data.userId == request.auth.uid &&
             data.createdAt == request.time &&
             data.message is string && data.message.size() <= 200;
    }
    
    function isValidChatMessage(data) {
      return data.keys().hasAll(['text', 'author', 'userId', 'createdAt']) &&
             data.keys().size() == 4 &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 500 &&
             data.author is string && data.author.size() <= 50 &&
             data.userId == request.auth.uid &&
             data.createdAt == request.time;
    }
    
    function isValidTimelinePost(data) {
      return data.keys().hasAll(['text', 'author', 'userId', 'mediaUrl', 'mediaType', 'createdAt']) &&
             data.keys().size() == 6 &&
             data.text is string && data.text.size() <= 1000 &&
             data.author is string && data.author.size() <= 50 &&
             data.userId == request.auth.uid &&
             data.mediaUrl is string && data.mediaUrl.size() <= 600000 &&
             data.mediaType is string && data.mediaType.matches('^(image|video|none)$') &&
             data.createdAt == request.time;
    }

    function isValidPostComment(data) {
      return data.keys().hasAll(['text', 'author', 'userId', 'createdAt']) &&
             data.keys().size() == 4 &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 500 &&
             data.author is string && data.author.size() <= 50 &&
             data.userId == request.auth.uid &&
             data.createdAt == request.time;
    }
    
    function isValidGangMember(data) {
      return data.keys().hasAll(['name', 'role', 'image', 'createdAt']) &&
             (!data.keys().hasAny(['twitter']) || (data.twitter is string && data.twitter.size() <= 600)) &&
             (!data.keys().hasAny(['kick']) || (data.kick is string && data.kick.size() <= 600)) &&
             (!data.keys().hasAny(['kickUsername']) || (data.kickUsername is string && data.kickUsername.size() <= 100)) &&
             data.name is string && data.name.size() <= 100 &&
             data.role is string && data.role.size() <= 100 &&
             data.image is string && data.image.size() <= 600000 &&
             data.createdAt == request.time;
    }
    
    function isValidLiveStream(data) {
      return data.keys().hasAll(['title', 'url', 'status', 'streamerName', 'createdAt']) &&
             (!data.keys().hasAny(['imageUrl']) || (data.imageUrl is string && data.imageUrl.size() <= 500000)) &&
             data.title is string && data.title.size() <= 100 &&
             data.url is string && data.url.size() <= 500 &&
             data.status is string && data.status in ['live', 'offline'] &&
             data.streamerName is string && data.streamerName.size() <= 50 &&
             data.createdAt == request.time;
    }
    
    match /gangMembers/{memberId} {
      allow read: if true;
      allow create: if isValidId(memberId) && isAdmin() && isValidGangMember(incoming());
      allow update: if isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'role', 'image', 'twitter', 'kick', 'kickUsername']) &&
                    (!incoming().keys().hasAny(['twitter']) || (incoming().twitter is string && incoming().twitter.size() <= 600)) &&
                    (!incoming().keys().hasAny(['kick']) || (incoming().kick is string && incoming().kick.size() <= 600)) &&
                    (!incoming().keys().hasAny(['kickUsername']) || (incoming().kickUsername is string && incoming().kickUsername.size() <= 100)) &&
                    (!incoming().keys().hasAny(['name']) || (incoming().name is string && incoming().name.size() <= 100)) &&
                    (!incoming().keys().hasAny(['role']) || (incoming().role is string && incoming().role.size() <= 100)) &&
                    (!incoming().keys().hasAny(['image']) || (incoming().image is string && incoming().image.size() <= 600000));
      allow delete: if isAdmin();
    }
    
    match /streams/{streamId} {
      allow read: if true;
      allow create: if isValidId(streamId) && isAdmin() && isValidLiveStream(incoming());
      allow update: if isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'url', 'status', 'streamerName', 'imageUrl']) &&
                    (!incoming().keys().hasAny(['title']) || (incoming().title is string && incoming().title.size() <= 100)) &&
                    (!incoming().keys().hasAny(['url']) || (incoming().url is string && incoming().url.size() <= 500)) &&
                    (!incoming().keys().hasAny(['status']) || (incoming().status is string && incoming().status in ['live', 'offline'])) &&
                    (!incoming().keys().hasAny(['streamerName']) || (incoming().streamerName is string && incoming().streamerName.size() <= 50)) &&
                    (!incoming().keys().hasAny(['imageUrl']) || (incoming().imageUrl is string && incoming().imageUrl.size() <= 500000));
      allow delete: if isAdmin();
    }
    
    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming()) && 
                    (incoming().role == 'user' || (incoming().role in ['admin', 'owner'] && isOwnerAdmin()));
      
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']) && (!incoming().keys().hasAny(['displayName']) || (incoming().displayName is string && incoming().displayName.size() <= 50)) && (!incoming().keys().hasAny(['photoURL']) || (incoming().photoURL is string && incoming().photoURL.size() <= 600000))) ||
        (isOwnerAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['role']) && incoming().role in ['user', 'admin', 'owner'])
      );
      allow delete: if false;
    }

    match /photos/{photoId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(photoId) && isValidPhotoPost(incoming());
      allow update: if false; 
      allow delete: if isAdmin() || (isSignedIn() && 'userId' in existing() && existing().userId == request.auth.uid);
    }
    
    match /messages/{messageId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(messageId) && isValidChatMessage(incoming());
      allow update: if false;
      allow delete: if isAdmin() || (isSignedIn() && 'userId' in existing() && existing().userId == request.auth.uid);
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(postId) && isValidTimelinePost(incoming());
      allow update: if false;
      allow delete: if isAdmin() || (isSignedIn() && 'userId' in existing() && existing().userId == request.auth.uid);

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && isValidId(commentId) && isValidPostComment(incoming());
        allow update: if false;
        allow delete: if isAdmin() || (isSignedIn() && 'userId' in existing() && existing().userId == request.auth.uid);
      }
    }
  }
}
